# JobHubMine Configuration

# ── Main Scraper (Gupy / Inhire) ──────────────────────────────────────────

# Enable/Disable scrapers
GUPY_ENABLED=true
INHIRE_ENABLED=true

# Number of companies to fetch from APIs
GUPY_COMPANY_LIMIT=30
INHIRE_COMPANY_LIMIT=10

# Parallel worker threads for scraping
GUPY_THREADS=16
INHIRE_THREADS=16

# ── API ────────────────────────────────────────────────────────────────────

# JOBHUBMINE_DATABASE=/app/out/jobhubmine.db
# DEBUG=false
# PORT=5000

# ── Web ────────────────────────────────────────────────────────────────────

# API_URL=http://api:5000

# ── Selenium Scraper (LinkedIn) ───────────────────────────────────────────

# Selenium / WebDriver
SELENIUM_URL=http://firefox:4444/wd/hub
BROWSER_TIMEOUT=30
IMPLICIT_WAIT=10

# LinkedIn search parameters
LINKEDIN_KEYWORDS=Software Engineer
LINKEDIN_LOCATION=Brazil
LINKEDIN_JOB_LIMIT=50
SCRAPE_DETAIL_PAGES=false

# Anti-detection delays (seconds, randomised between min and max)
DELAY_MIN=0.3
DELAY_MAX=3.0
PAGE_LOAD_DELAY_MIN=3.0
PAGE_LOAD_DELAY_MAX=7.0

# Retry behaviour
RETRY_ATTEMPTS=3
RETRY_DELAY=10.0
SCROLL_WAIT_SECONDS=5.0
SCROLL_WAIT_RETRIES=6

# Logging
LOG_LEVEL_STDOUT=INFO
LOG_LEVEL_FILE=DEBUG
LOG_DIR=/app/logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Output
OUTPUT_DIR=/app/out
